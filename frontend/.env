# File: frontend/.env
# Purpose: CRA reads these at build time. Variables MUST start with REACT_APP_.
# This file is committed to git (no secrets here — all auth is via Spring Boot).

# Spring Boot backend base URL
# The "proxy" in package.json handles /api/* in dev, but set this for explicit control
REACT_APP_API_URL=http://localhost:8080

# App name shown in browser tab and meta tags
REACT_APP_NAME=UniAI Platform

# Feature flags
REACT_APP_ENABLE_ODIA=true

# Optional: set to "true" to show mock analytics even when DB has no data
REACT_APP_DEMO_MODE=true
