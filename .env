# =============================================================================
# File: university-ai-platform/.env
# Purpose: Root environment file read by docker-compose.
#          Values here can be referenced in docker-compose.yml as ${VAR_NAME}.
#
# IMPORTANT: Add this file to .gitignore. Never commit API keys.
# =============================================================================

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=university_ai_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Change this to a random 256-bit string in production
JWT_SECRET=university-ai-platform-super-secret-jwt-key-change-in-production-2024

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Set GEMINI_API_KEY or OPENAI_API_KEY — the ai-service/.env overrides these
# but you can also set them here as fallback
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
LLM_PROVIDER=gemini
